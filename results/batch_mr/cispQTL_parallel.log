> # ‚îÄ‚îÄ Harmonize & MR (lightweight) ‚îÄ‚îÄ
> # Allele harmonization: flip outcome beta if alleles swapped or complement
> harmonize_alleles <- function(ea_exp, oa_exp, ea_out, oa_out) {
+   # Returns multiplier: 1 = same strand, -1 = flip needed, NA = incompatible
+   m <- rep(NA_real_, length(ea_exp))
+   # Same strand match
+   same <- (ea_exp == ea_out) & (oa_exp == oa_out)
+   m[same] <- 1
+   # Flip strand match (complement)
+   flip <- (ea_exp == oa_out) & (oa_exp == ea_out)
+   m[flip] <- 1  # Already matched by harmonise, this is fine
+   # Palindromic check
+   pal <- (ea_exp == complement(oa_exp)) | (ea_exp == complement(ea_out))
+   return(list(mult = m, pal = pal))
+ }
> 
> complement <- function(x) {
+   x[x=="A"] <- "T"; x[x=="T"] <- "A"; x[x=="C"] <- "G"; x[x=="G"] <- "C"; x
+ }
> 
> # Wald ratio: beta_mr = beta_out / beta_exp, se_mr = se_out / |beta_exp|
> wald_ratio <- function(b_exp, se_exp, b_out, se_out, mult) {
+   b_out_adj <- b_out * mult  # Flip if alleles differ
+   b_mr <- b_out_adj / b_exp
+   se_mr <- se_out / abs(b_exp)
+   p_mr <- 2 * pnorm(-abs(b_mr / se_mr))
+   data.frame(b = b_mr, se = se_mr, pval = p_mr)
+ }
> 
> # IVW fixed effects (for >=2 SNPs)
> ivw_fe <- function(b_exp, se_exp, b_out, se_out, mult) {
+   b_out_adj <- b_out * mult
+   b_mr_i <- b_out_adj / b_exp   # per-SNP Wald estimates
+   se_mr_i <- se_out / abs(b_exp)
+   w <- 1 / se_mr_i^2
+   b_ivw <- sum(w * b_mr_i) / sum(w)
+   se_ivw <- sqrt(1 / sum(w))
+   p_ivw <- 2 * pnorm(-abs(b_ivw / se_ivw))
+   # Cochran's Q
+   Q <- sum(w * (b_mr_i - b_ivw)^2)
+   Q_pval <- pchisq(Q, length(b_exp) - 1, lower.tail = FALSE)
+   data.frame(b = b_ivw, se = se_ivw, pval = p_ivw, Q = Q, Q_df = length(b_exp)-1, Q_pval = Q_pval)
+ }
> 
> # ‚îÄ‚îÄ Process one platform ‚îÄ‚îÄ
> process_platform <- function(plat_name, csv_path) {
+   t1 <- Sys.time()
+   cat(sprintf("[%s] Loading...\n", plat_name))
+   raw <- suppressMessages(fread(csv_path, data.table = FALSE, showProgress = FALSE))
+   if (!"id.exposure" %in% names(raw))
+     raw$id.exposure <- if ("info.exposure" %in% names(raw)) raw$info.exposure else raw$exposure
+   raw$id.exposure <- as.character(raw$id.exposure)
+   proteins <- unique(raw$id.exposure)
+   cat(sprintf("[%s] %d proteins\n", plat_name, length(proteins)))
+ 
+   results <- list(); n_ok <- 0; n_skip <- 0
+   for (i in seq_along(proteins)) {
+     pid <- proteins[i]; inst <- raw[raw$id.exposure == pid, ]
+     matched <- mig[inst$SNP, nomatch = NULL]
+     if (nrow(matched) < 1) { n_skip <- n_skip + 1; next }
+ 
+     # Merge by SNP
+     m <- merge(inst, matched, by = "SNP", suffixes = c(".exp", ".out"))
+     if (nrow(m) < 1) { n_skip <- n_skip + 1; next }
+ 
+     # Harmonize: handle allele mismatches
+     # Effect allele exposure vs outcome
+     ea_same <- m$effect_allele.exposure == m$alt
+     ea_comp <- m$effect_allele.exposure == m$ref
+     mult <- ifelse(ea_same, 1, ifelse(ea_comp, -1, NA))
+     if (any(is.na(mult))) { n_skip <- n_skip + 1; next }
+ 
+     # Palindromic check: skip palindromic SNPs with intermediate AF
+     pal <- (m$effect_allele.exposure == complement_char(m$other_allele.exposure))
+     if (any(pal)) {
+       keep <- !pal
+       if (sum(keep) < 1) { n_skip <- n_skip + 1; next }
+       m <- m[keep, ]; mult <- mult[keep]
+     }
+ 
+     # MR
+     if (nrow(m) == 1) {
+       mr <- wald_ratio(m$beta.exposure[1], m$se.exposure[1],
+                        m$beta[1], m$se[1], mult[1])
+     } else {
+       mr <- ivw_fe(m$beta.exposure, m$se.exposure,
+                    m$beta, m$se, mult)
+     }
+ 
+     gname <- if ("gene.exposure" %in% names(inst)) inst$gene.exposure[1]
+              else gsub(" \\|\\|.*", "", inst$exposure[1])
+ 
+     res <- data.frame(protein_id = pid, protein_name = gname,
+       nsnp = nrow(m), b = mr$b, se = mr$se, pval = mr$pval,
+       stringsAsFactors = FALSE)
+     results[[length(results) + 1]] <- res; n_ok <- n_ok + 1
+   }
+ 
+   all <- rbindlist(results); all <- as.data.frame(all)
+   all$fdr_q <- p.adjust(all$pval, method = "fdr")
+   all$bonf_thresh <- 0.05 / nrow(all)
+   all$bonf_sig <- all$pval < all$bonf_thresh
+   all$or <- exp(all$b)
+   all <- all[order(all$pval), ]
+   fwrite(all, file.path(OUT, sprintf("cispQTL_mr_%s.csv", plat_name)))
+ 
+   dt <- difftime(Sys.time(), t1, units = "secs")
+   cat(sprintf("[%s] DONE %d proteins | Bonf: %d | FDR<0.05: %d | Top P=%.2e (%s) | %.0fs\n",
+               plat_name, nrow(all), sum(all$bonf_sig), sum(all$fdr_q < 0.05),
+               all$pval[1], all$protein_name[1], as.numeric(dt)))
+   all
+ }
> 
> complement_char <- function(x) {
+   chartr("ACGT", "TGCA", x)
+ }
> 
